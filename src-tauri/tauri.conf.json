{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentique UI",
  "version": "0.1.0",
  "identifier": "io.agentique.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agentique UI",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://www.agentique.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "rpm", "appimage"],
    "publisher": "Agentique",
    "category": "DeveloperTool",
    "shortDescription": "Local-first workspace for Agentique resources.",
    "longDescription": "Agentique UI verifies, inspects, configures, previews, and hands off supported Agentique resources on a user's own machine.",
    "copyright": "Copyright Agentique contributors. All rights reserved.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png", "icons/icon.ico"],
    "createUpdaterArtifacts": false
  }
}
