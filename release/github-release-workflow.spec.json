{
  "schemaVersion": "agentique.githubReleaseWorkflowGate.v1",
  "workflowPath": ".github/workflows/draft-release.yml",
  "trigger": "workflow_dispatch",
  "publicationMode": "draft-only",
  "requiredRunners": ["windows-latest", "macos-14", "ubuntu-22.04"],
  "requiredBuildScripts": ["tauri:build:windows", "tauri:build:macos", "tauri:build:linux"],
  "requiredEvidence": ["full-validation", "checksums", "sbom", "cargo-metadata", "artifact-attestation", "draft-release"],
  "permissions": {
    "contents": "write",
    "id-token": "write",
    "attestations": "write"
  },
  "allowedActionOwners": ["actions"],
  "releaseSafety": {
    "requiresDraft": true,
    "requiresManualDispatch": true,
    "stablePublishOutsideWorkflow": true
  }
}
