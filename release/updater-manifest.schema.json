{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.agentique.io/schemas/agentique-ui-updater-manifest.schema.json",
  "title": "Agentique UI updater manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "notes", "pub_date", "platforms"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "pub_date": {
      "type": "string",
      "format": "date-time"
    },
    "platforms": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signature", "url"],
        "properties": {
          "signature": {
            "type": "string",
            "minLength": 16
          },
          "url": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          }
        }
      }
    }
  }
}
