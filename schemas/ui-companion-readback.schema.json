{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentique.io/ui/ui-companion-readback.v1.schema.json",
  "title": "Agentique UI Companion Readback",
  "type": "object",
  "required": [
    "schemaVersion",
    "resource",
    "download",
    "support",
    "provenance",
    "compatibility"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agentique.uiCompanionReadback.v1"
    },
    "resource": {
      "type": "object",
      "required": ["id", "version", "title", "canonicalUrl"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "summary": {
          "type": "string",
          "maxLength": 500
        },
        "canonicalUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      },
      "unevaluatedProperties": false
    },
    "download": {
      "type": "object",
      "required": ["ticketEndpoint", "maxBytes"],
      "properties": {
        "ticketEndpoint": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483648
        }
      },
      "unevaluatedProperties": false
    },
    "support": {
      "type": "object",
      "required": ["modes", "primaryMode", "minimumCompleteUx"],
      "properties": {
        "modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "catalog-only",
              "visualizable",
              "editable",
              "dry-runnable",
              "locally-runnable",
              "external-handoff"
            ]
          }
        },
        "primaryMode": {
          "enum": [
            "catalog-only",
            "visualizable",
            "editable",
            "dry-runnable",
            "locally-runnable",
            "external-handoff"
          ]
        },
        "minimumCompleteUx": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        }
      },
      "unevaluatedProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["publishedDigest", "verificationStatus"],
      "properties": {
        "publishedDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "verificationStatus": {
          "enum": ["verified", "reviewed", "unverified"]
        },
        "signer": {
          "type": "string",
          "maxLength": 160
        }
      },
      "unevaluatedProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": ["agentiqueUi", "platforms", "schemaRefs"],
      "properties": {
        "agentiqueUi": {
          "type": "string",
          "pattern": "^>=\\d+\\.\\d+\\.\\d+$"
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["windows", "macos", "linux"]
          },
          "uniqueItems": true
        },
        "schemaRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "uniqueItems": true
        }
      },
      "unevaluatedProperties": false
    }
  },
  "unevaluatedProperties": false
}
